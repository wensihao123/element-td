[ext_resource type="Resource" path="res://data/elements/poison.tres" id="3_poison"]
[ext_resource type="Script" path="res://scripts/effects/dot_effect.gd" id="4_dot"]
[ext_resource type="Script" path="res://scripts/effects/propagate_effect.gd" id="5_prop"]
[ext_resource type="Script" path="res://scripts/effects/reaction_effect.gd" id="6_fx"]

[sub_resource type="Resource" id="fx_dot_main"]
script = ExtResource("4_dot")
